<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.StackPane?>

<!-- fx:controller links this fxml to LoginController.java -->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="LoginController"
      styleClass="root-container"
      spacing="0">

    <!-- TOP HEADER BAR -->
    <VBox styleClass="header-bar" spacing="4">
        <Label text="Hostel Electricity Tracker" styleClass="header-title"/>
        <Label text="Please login to continue"   styleClass="header-sub"/>
    </VBox>

    <!-- FORM AREA -->
    <VBox styleClass="form-area" spacing="14">

        <!-- Username row -->
        <Label text="Username" styleClass="form-label"/>
        <!-- fx:id links this field to LoginController variable -->
        <TextField fx:id="usernameField"
                   promptText="Enter username"
                   styleClass="form-input"/>

        <!-- Password row -->
        <Label text="Password" styleClass="form-label"/>
        <PasswordField fx:id="passwordField"
                       promptText="Enter password"
                       styleClass="form-input"/>

        <!-- Error message label (hidden by default) -->
        <Label fx:id="errorLabel"
               text=""
               styleClass="error-label"/>

        <!-- Login Button -->
        <!-- onAction links to handleLogin() method in controller -->
        <Button text="LOGIN"
                onAction="#handleLogin"
                styleClass="login-btn"/>

        <!-- Hint label showing test credentials -->
        <Label text="Student: rahul123 / pass123   |   Admin: warden01 / admin999"
               styleClass="hint-label"/>

    </VBox>

</VBox>